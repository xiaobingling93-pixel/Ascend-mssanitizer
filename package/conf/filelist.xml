<?xml version="1.0" encoding="UTF-8"?>
<config name="mindstudio-sanitizer" dst_path="mindstudio-sanitizer" install_path="mindstudio-sanitizer" install_own="$username:$usergroup" install_mod="550">
    <!-- install directory -->
    <dir_info value="common" install_mod="550">
        <path value="${TARGET_ENV}"/>
        <path value="${TARGET_ENV}/bin" install_softlink="bin"/>
        <path value="tools" install_mod="750"/>
    </dir_info>

    <dir_info value="mindstudio-sanitizer">
        <path value="share/info/mindstudio-sanitizer/script"/>
        <path value="tools/mssanitizer"/>
        <path value="tools/mssanitizer/bin"/>
        <path value="tools/mssanitizer/lib64"/>
        <path value="tools/mssanitizer/include"/>
    </dir_info>

    <file_info value="install_info" copy_type="delivery" src_path="" dst_path="share/info/mindstudio-sanitizer" install_path="share/info/mindstudio-sanitizer" install_mod="440">
        <file value="version.info"/>
        <file value="scene.info"/>
    </file_info>

    <file_info value="scripts" copy_type="source" src_path="package/script" dst_path="share/info/mindstudio-sanitizer/script" install_path="share/info/mindstudio-sanitizer/script" install_mod="550">
        <file value="install.sh"/>
        <file value="uninstall.sh"/>
        <file value="cann_uninstall.sh"/>
        <file value="common.sh"/>
        <file value="parser_install.sh" copy_type="delivery" src_path=""/>
        <file value="filelist.csv" copy_type="delivery" src_path="" install_mod="440"/>
        <file value="help.info" src_path="package/conf" install_mod="440"/>
    </file_info>

    <file_info value="mssanitizer/bin" copy_type="source" src_path="${OUTPUT}/bin" dst_path="mindstudio-sanitizer/tools/mssanitizer/bin" install_path="tools/mssanitizer/bin" install_mod="550">
        <file value="mssanitizer" install_softlink="${TARGET_ENV}/bin/mssanitizer"/>
        <file value="mssanitizer.bin" />
        <file value="kernel-launcher" />
        <file value="llvm-symbolizer" />
    </file_info>

    <file_info value="mssanitizer/include" copy_type="source" src_path="${OUTPUT}/include" dst_path="mindstudio-sanitizer/tools/mssanitizer/include" install_path="tools/mssanitizer/include">
        <file value="acl"/>
        <file value="sanitizer.h"/>
        <file value="sanitizer_report.h"/>
    </file_info>

    <file_info value="mssanitizer/lib64" copy_type="source" src_path="${OUTPUT}/lib64" dst_path="mindstudio-sanitizer/tools/mssanitizer/lib64" install_path="tools/mssanitizer/lib64" install_mod="440">
        <file value="libascend_san.so"/>
        <file value="libascend_san.so.26.0.0"/>
        <file value="libascend_san_stub.so"/>
        <file value="libascend_san_stub.so.26.0.0"/>
        <file value="libascend_acl_hook.so"/>
        <file value="libascend_hal_hook.so"/>
        <file value="libascendc_hook.so"/>
        <file value="libmssanitizer_injection.so"/>
        <file value="libsanitizer_api.so"/>
        <file value="libsanitizer_stub_dav-m200.a"/>
        <file value="libsanitizer_stub_dav-m200-vec.a"/>
        <file value="libsanitizer_stub_dav-c220-vec.a"/>
        <file value="libsanitizer_stub_dav-c220-cube.a"/>
        <file value="libsanitizer_stub_dav-c220.a"/>
        <file value="libsanplugin_boundscheck.so"/>
    </file_info>
</config>
